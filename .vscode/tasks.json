{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-launcher",
      "type": "shell",
      "command": "C:/msys64/mingw64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${workspaceFolder}/src/launcher.cpp",
        "-o",
        "${workspaceFolder}/bin/launcher.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/msys64/mingw64/bin;${env:PATH}"
        }
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "compiler: C:/msys64/mingw64/bin/g++.exe"
    },
    {
      "label": "build-2d",
      "type": "shell",
      "command": "C:/msys64/mingw64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${workspaceFolder}/src/atom.cpp",
        "-o",
        "${workspaceFolder}/bin/atom.exe",
        "-IC:/msys64/mingw64/include",
        "-LC:/msys64/mingw64/lib",
        "-lglfw3",
        "-lglew32",
        "-lopengl32",
        "-lgdi32"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/msys64/mingw64/bin;${env:PATH}"
        }
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "compiler: C:/msys64/mingw64/bin/g++.exe"
    },
    {
      "label": "build-realtime",
      "type": "shell",
      "command": "C:/msys64/mingw64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${workspaceFolder}/src/atom_realtime.cpp",
        "-o",
        "${workspaceFolder}/bin/atom_realtime.exe",
        "-IC:/msys64/mingw64/include",
        "-LC:/msys64/mingw64/lib",
        "-lglfw3",
        "-lglew32",
        "-lopengl32",
        "-lgdi32"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/msys64/mingw64/bin;${env:PATH}"
        }
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "compiler: C:/msys64/mingw64/bin/g++.exe"
    },
    {
      "label": "build-raytracer",
      "type": "shell",
      "command": "C:/msys64/mingw64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${workspaceFolder}/src/atom_raytracer.cpp",
        "-o",
        "${workspaceFolder}/bin/atom_raytracer.exe",
        "-IC:/msys64/mingw64/include",
        "-LC:/msys64/mingw64/lib",
        "-lglfw3",
        "-lglew32",
        "-lopengl32",
        "-lgdi32"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/msys64/mingw64/bin;${env:PATH}"
        }
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "compiler: C:/msys64/mingw64/bin/g++.exe"
    },
    {
      "label": "build-wave",
      "type": "shell",
      "command": "C:/msys64/mingw64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${workspaceFolder}/src/wave_atom_2d.cpp",
        "-o",
        "${workspaceFolder}/bin/wave_atom_2d.exe",
        "-IC:/msys64/mingw64/include",
        "-LC:/msys64/mingw64/lib",
        "-lglfw3",
        "-lglew32",
        "-lopengl32",
        "-lgdi32"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/msys64/mingw64/bin;${env:PATH}"
        }
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "compiler: C:/msys64/mingw64/bin/g++.exe"
    },
    {
      "label": "build-excitation",
      "type": "shell",
      "command": "C:/msys64/mingw64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${workspaceFolder}/src/atom_excitation.cpp",
        "-o",
        "${workspaceFolder}/bin/atom_excitation.exe",
        "-IC:/msys64/mingw64/include",
        "-LC:/msys64/mingw64/lib",
        "-lglfw3",
        "-lglew32",
        "-lopengl32",
        "-lgdi32"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/msys64/mingw64/bin;${env:PATH}"
        }
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "compiler: C:/msys64/mingw64/bin/g++.exe"
    },
    {
      "label": "build-all",
      "dependsOn": [
        "build-launcher",
        "build-2d",
        "build-realtime",
        "build-raytracer",
        "build-wave",
        "build-excitation"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build-cuda",
      "type": "shell",
      "command": "\"C:/Program Files/NVIDIA GPU Computing Toolkit/CUDA/v12.8/bin/nvcc.exe\"",
      "args": [
        "-o",
        "-IC:/msys64/mingw64/include",
        "-IC:/Program Files/NVIDIA GPU Computing Toolkit/CUDA/v12.8/include",
        "-LC:/msys64/mingw64/lib",
        "-LC:/Program Files/NVIDIA GPU Computing Toolkit/CUDA/v12.8/lib/x64",
        "-lglfw3",
        "-lglew32",
        "-lopengl32",
        "-lgdi32",
        "-lcudart"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build"
    }
  ]
}

